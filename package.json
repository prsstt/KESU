{
  "name": "kesu",
  "version": "2.0.0",
  "description": "Professional Discord Message Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.parasite.kesu",
    "productName": "Kesu",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "parasite",
        "repo": "kesu"
      }
    ]
  }
}
